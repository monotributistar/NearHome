generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                    String                   @id @default(cuid())
  name                  String
  createdAt             DateTime                 @default(now())
  deletedAt             DateTime?
  memberships           Membership[]
  cameras               Camera[]
  subscriptions         Subscription[]
  events                Event[]
  streamSessions        StreamSession[]
  auditLogs             AuditLog[]
  detectionJobs         DetectionJob[]
  detectionObservations DetectionObservation[]
  tracks                Track[]
  scenePrimitiveEvents  ScenePrimitiveEvent[]
  incidentEvents        IncidentEvent[]
  incidentEvidence      IncidentEvidence[]
  inferenceProviderConfigs InferenceProviderConfig[]
  inferenceNodeSnapshots   InferenceNodeSnapshot[]
  inferenceNodeAssignments InferenceNodeTenantAssignment[]
  notificationChannels     NotificationChannel[]
  notificationDeliveries   NotificationDelivery[]
  cameraAssignments        CameraAssignment[]
  households               Household[]
  householdMembers         HouseholdMember[]
  subscriptionRequests     SubscriptionRequest[]
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String
  createdAt    DateTime     @default(now())
  isActive     Boolean      @default(true)
  memberships  Membership[]
  streamSessions StreamSession[]
  cameraAssignments CameraAssignment[]
  householdsCreated Household[]
  householdMembersCreated HouseholdMember[]
  subscriptionRequestsCreated SubscriptionRequest[] @relation("SubscriptionRequestCreatedBy")
  subscriptionRequestsReviewed SubscriptionRequest[] @relation("SubscriptionRequestReviewedBy")
}

model Membership {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
}

model Camera {
  id                    String                @id @default(cuid())
  tenantId              String
  name                  String
  description           String?
  rtspUrl               String
  location              String?
  tags                  String
  isActive              Boolean               @default(true)
  lifecycleStatus       String                @default("draft")
  lastSeenAt            DateTime?
  lastTransitionAt      DateTime?
  createdAt             DateTime              @default(now())
  deletedAt             DateTime?
  tenant                Tenant                @relation(fields: [tenantId], references: [id])
  events                Event[]
  profile               CameraProfile?
  lifecycleLogs         CameraLifecycleLog[]
  latestHealthSnapshot  CameraHealthSnapshot?
  streamSessions        StreamSession[]
  detectionJobs         DetectionJob[]
  detectionObservations DetectionObservation[]
  tracks                Track[]
  scenePrimitiveEvents  ScenePrimitiveEvent[]
  incidentEvents        IncidentEvent[]
  notificationDeliveries NotificationDelivery[]
  assignments           CameraAssignment[]
}

model CameraAssignment {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  cameraId  String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  camera    Camera   @relation(fields: [cameraId], references: [id])

  @@unique([tenantId, userId, cameraId])
  @@index([tenantId, userId])
}

model CameraProfile {
  id                  String   @id @default(cuid())
  tenantId            String
  cameraId            String   @unique
  proxyPath           String
  recordingEnabled    Boolean  @default(false)
  recordingStorageKey String
  detectorConfigKey   String
  detectorResultsKey  String
  detectorFlags       String
  zoneMap             String?
  homography          String?
  sceneTags           String?
  rulesProfile        String?
  detectionProfile    String?
  status              String   @default("ready")
  lastHealthAt        DateTime?
  lastError           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  camera              Camera   @relation(fields: [cameraId], references: [id])
}

model CameraLifecycleLog {
  id          String   @id @default(cuid())
  tenantId    String
  cameraId    String
  fromStatus  String?
  toStatus    String
  event       String
  reason      String?
  actorUserId String?
  createdAt   DateTime @default(now())
  camera      Camera   @relation(fields: [cameraId], references: [id])
}

model CameraHealthSnapshot {
  id          String   @id @default(cuid())
  tenantId    String
  cameraId    String   @unique
  connectivity String
  latencyMs   Int?
  packetLossPct Float?
  jitterMs    Int?
  error       String?
  checkedAt   DateTime @default(now())
  camera      Camera   @relation(fields: [cameraId], references: [id])
}

model Plan {
  id        String         @id @default(cuid())
  code      String         @unique
  name      String
  limits    String
  features  String
  createdAt DateTime       @default(now())
  subscriptions Subscription[]
  subscriptionRequests SubscriptionRequest[]
}

model Subscription {
  id                 String   @id @default(cuid())
  tenantId           String
  planId             String
  status             String
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt          DateTime @default(now())
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  plan               Plan     @relation(fields: [planId], references: [id])

  @@unique([tenantId])
}

model SubscriptionRequest {
  id                 String   @id @default(cuid())
  tenantId           String
  planId             String
  requestedByUserId  String
  status             String   @default("pending_review")
  proofImageUrl      String
  proofFileName      String
  proofMimeType      String
  proofSizeBytes     Int
  proofMetadata      String?
  notes              String?
  reviewedByUserId   String?
  reviewNotes        String?
  reviewedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  plan               Plan     @relation(fields: [planId], references: [id])
  requestedByUser    User     @relation("SubscriptionRequestCreatedBy", fields: [requestedByUserId], references: [id])
  reviewedByUser     User?    @relation("SubscriptionRequestReviewedBy", fields: [reviewedByUserId], references: [id])

  @@index([tenantId, status, createdAt])
}

model Event {
  id        String   @id @default(cuid())
  tenantId  String
  cameraId  String
  type      String
  severity  String
  timestamp DateTime
  payload   String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  camera    Camera   @relation(fields: [cameraId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?
  resource    String
  action      String
  resourceId  String?
  payload     String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model Household {
  id              String            @id @default(cuid())
  tenantId        String
  name            String
  address         String?
  notes           String?
  isActive        Boolean           @default(true)
  createdByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  createdByUser   User?             @relation(fields: [createdByUserId], references: [id])
  members         HouseholdMember[]

  @@index([tenantId, createdAt])
}

model HouseholdMember {
  id              String    @id @default(cuid())
  tenantId        String
  householdId     String
  fullName        String
  relationship    String
  phone           String?
  canViewCameras  Boolean   @default(true)
  canReceiveAlerts Boolean  @default(true)
  isActive        Boolean   @default(true)
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  household       Household @relation(fields: [householdId], references: [id])
  createdByUser   User?     @relation(fields: [createdByUserId], references: [id])

  @@index([tenantId, householdId, createdAt])
}

model StreamSession {
  id            String                    @id @default(cuid())
  tenantId      String
  cameraId      String
  userId        String
  status        String
  token         String
  expiresAt     DateTime
  issuedAt      DateTime
  activatedAt   DateTime?
  endedAt       DateTime?
  endReason     String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  tenant        Tenant                    @relation(fields: [tenantId], references: [id])
  camera        Camera                    @relation(fields: [cameraId], references: [id])
  user          User                      @relation(fields: [userId], references: [id])
  transitions   StreamSessionTransition[]
}

model StreamSessionTransition {
  id              String        @id @default(cuid())
  streamSessionId String
  tenantId        String
  fromStatus      String?
  toStatus        String
  event           String
  actorUserId     String?
  createdAt       DateTime      @default(now())
  streamSession   StreamSession @relation(fields: [streamSessionId], references: [id])
}

model DetectionJob {
  id            String   @id @default(cuid())
  tenantId      String
  cameraId      String
  mode          String
  source        String
  provider      String
  status        String
  workflowId    String?
  runId         String?
  errorCode     String?
  errorMessage  String?
  options       String?
  queuedAt      DateTime @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  canceledAt    DateTime?
  createdByUserId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  camera        Camera   @relation(fields: [cameraId], references: [id])
  observations  DetectionObservation[]
  tracks        Track[]
  scenePrimitiveEvents ScenePrimitiveEvent[]
  incidentEvents IncidentEvent[]

  @@index([tenantId, cameraId, status])
}

model DetectionObservation {
  id              String   @id @default(cuid())
  jobId           String
  tenantId        String
  cameraId        String
  frameTs         DateTime
  label           String
  confidence      Float
  bbox            String
  keypoints       String?
  attributes      String?
  providerMeta    String?
  createdAt       DateTime @default(now())
  job             DetectionJob @relation(fields: [jobId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  camera          Camera   @relation(fields: [cameraId], references: [id])
  evidence        IncidentEvidence[]

  @@index([tenantId, cameraId, frameTs])
  @@index([jobId])
}

model Track {
  id              String   @id @default(cuid())
  jobId           String?
  tenantId        String
  cameraId        String
  classLabel      String
  trackExternalId String
  startedAt       DateTime
  endedAt         DateTime?
  metadata        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  job             DetectionJob? @relation(fields: [jobId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  camera          Camera   @relation(fields: [cameraId], references: [id])
  points          TrackPoint[]
  evidence        IncidentEvidence[]

  @@index([tenantId, cameraId, startedAt])
  @@unique([tenantId, cameraId, trackExternalId])
}

model TrackPoint {
  id          String   @id @default(cuid())
  trackId     String
  ts          DateTime
  x           Float
  y           Float
  zoneId      String?
  speed       Float?
  createdAt   DateTime @default(now())
  track       Track    @relation(fields: [trackId], references: [id])

  @@index([trackId, ts])
}

model ScenePrimitiveEvent {
  id            String   @id @default(cuid())
  tenantId      String
  cameraId      String
  jobId         String?
  type          String
  severity      String
  startedAt     DateTime
  endedAt       DateTime?
  payload       String?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  camera        Camera   @relation(fields: [cameraId], references: [id])
  job           DetectionJob? @relation(fields: [jobId], references: [id])
  incidents     IncidentEvidence[]

  @@index([tenantId, cameraId, startedAt])
}

model IncidentEvent {
  id            String   @id @default(cuid())
  tenantId      String
  cameraId      String
  jobId         String?
  type          String
  severity      String
  status        String
  summary       String
  startedAt     DateTime
  endedAt       DateTime?
  payload       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  camera        Camera   @relation(fields: [cameraId], references: [id])
  job           DetectionJob? @relation(fields: [jobId], references: [id])
  evidence      IncidentEvidence[]
  notificationDeliveries NotificationDelivery[]

  @@index([tenantId, cameraId, startedAt])
}

model NotificationChannel {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  type        String
  endpoint    String?
  authToken   String?
  headersJson String?
  emailTo     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  deliveries  NotificationDelivery[]

  @@index([tenantId, isActive])
}

model NotificationDelivery {
  id               String   @id @default(cuid())
  tenantId         String
  cameraId         String
  incidentId       String
  channelId        String?
  channelType      String
  status           String
  error            String?
  responseCode     Int?
  requestPayload   String?
  responsePayload  String?
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  camera           Camera   @relation(fields: [cameraId], references: [id])
  incident         IncidentEvent @relation(fields: [incidentId], references: [id])
  channel          NotificationChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([tenantId, cameraId, createdAt])
  @@index([incidentId])
}

model IncidentEvidence {
  id                   String   @id @default(cuid())
  tenantId             String
  incidentId           String
  observationId        String?
  trackId              String?
  scenePrimitiveEventId String?
  clipUrl              String?
  snapshotUrl          String?
  createdAt            DateTime @default(now())
  tenant               Tenant   @relation(fields: [tenantId], references: [id])
  incident             IncidentEvent @relation(fields: [incidentId], references: [id])
  observation          DetectionObservation? @relation(fields: [observationId], references: [id])
  track                Track? @relation(fields: [trackId], references: [id])
  scenePrimitiveEvent  ScenePrimitiveEvent? @relation(fields: [scenePrimitiveEventId], references: [id])

  @@index([tenantId, incidentId])
}

model InferenceProviderConfig {
  id                 String   @id @default(cuid())
  tenantId           String
  providerType       String
  endpoint           String
  authType           String
  authConfigEncrypted String?
  model              String?
  timeoutMs          Int      @default(15000)
  retries            Int      @default(2)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
}

model InferenceNodeSnapshot {
  id               String   @id @default(cuid())
  tenantId         String?
  nodeId           String
  runtime          String
  transport        String
  endpoint         String
  status           String
  resources        String
  capabilities     String
  models           String
  maxConcurrent    Int
  queueDepth       Int
  isDrained        Boolean  @default(false)
  lastHeartbeatAt  DateTime
  contractVersion  String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant?  @relation(fields: [tenantId], references: [id])
  assignments      InferenceNodeTenantAssignment[]
  desiredConfig    InferenceNodeDesiredConfig?

  @@unique([nodeId])
}

model InferenceNodeTenantAssignment {
  id        String   @id @default(cuid())
  nodeId    String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  node      InferenceNodeSnapshot @relation(fields: [nodeId], references: [nodeId], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([nodeId, tenantId])
  @@index([tenantId])
}

model ModelCatalogEntry {
  id          String   @id @default(cuid())
  provider    String
  taskType    String
  quality     String
  modelRef    String
  displayName String
  resources   String
  defaults    String?
  outputs     String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, taskType, quality, modelRef])
  @@index([provider, taskType, quality, status])
}

model InferenceNodeDesiredConfig {
  id               String   @id @default(cuid())
  nodeId           String   @unique
  runtime          String
  transport        String
  endpoint         String
  desiredResources String
  desiredModels    String
  desiredCapabilities String
  desiredTenantIds String
  maxConcurrent    Int
  contractVersion  String
  configVersion    Int      @default(1)
  lastAppliedAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  node             InferenceNodeSnapshot @relation(fields: [nodeId], references: [nodeId], onDelete: Cascade)
}
