{
  "name": "nearhome-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "setup": "bash scripts/setup.sh",
    "bootstrap": "bash scripts/setup.sh",
    "dev:api": "pnpm --filter @app/api dev",
    "dev:stream": "pnpm --filter @app/stream-gateway dev",
    "dev:event": "pnpm --filter @app/event-gateway dev",
    "dev:admin": "pnpm --filter @app/admin dev",
    "dev:portal": "pnpm --filter @app/portal dev",
    "dev:inference-bridge": "uvicorn apps/inference-bridge/app:app --host 0.0.0.0 --port 8090",
    "dev:stack:up": "docker compose -f infra/docker-compose.yml up -d",
    "dev:stack:down": "docker compose -f infra/docker-compose.yml down",
    "staging:stack:up:postgres": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.postgres-staging.yml up -d",
    "staging:stack:down:postgres": "docker compose -f infra/docker-compose.yml -f infra/docker-compose.postgres-staging.yml down",
    "pilot:stack:up:local": "bash scripts/pilot/stack-up.sh local",
    "pilot:stack:down:local": "bash scripts/pilot/stack-down.sh local",
    "pilot:stack:up:onprem": "bash scripts/pilot/stack-up.sh onprem",
    "pilot:stack:up:onprem:remote": "bash scripts/pilot/stack-up.sh onprem-remote",
    "pilot:stack:up:onprem:tunnel": "bash scripts/pilot/stack-up.sh onprem tunnel",
    "pilot:stack:sync-detection:onprem": "bash scripts/pilot/stack-sync-detection.sh onprem",
    "pilot:stack:sync-detection:onprem:remote": "bash scripts/pilot/stack-sync-detection.sh onprem-remote",
    "pilot:stack:down:onprem": "bash scripts/pilot/stack-down.sh onprem",
    "pilot:stack:down:onprem:remote": "bash scripts/pilot/stack-down.sh onprem-remote",
    "pilot:detection:export": "node scripts/detection/export-node-deployments.mjs",
    "pilot:smoke": "bash scripts/pilot/smoke-planes.sh",
    "pilot:smoke:detection-sync": "bash scripts/pilot/smoke-detection-sync.sh",
    "pilot:smoke:stack-sync-api": "bash scripts/pilot/smoke-stack-sync-api.sh",
    "pilot:harness:prepare": "bash scripts/pilot/virtual-harness.sh prepare",
    "pilot:harness:run": "bash scripts/pilot/virtual-harness.sh run",
    "pilot:harness:cleanup": "bash scripts/pilot/virtual-harness.sh cleanup",
    "pilot:harness": "bash scripts/pilot/virtual-harness.sh full",
    "pilot:harness:mock": "bash scripts/pilot/harness-mode.sh mock full",
    "pilot:harness:lan": "bash scripts/pilot/harness-mode.sh lan full",
    "db:reset": "pnpm --filter @app/api db:reset",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test:e2e": "pnpm db:reset && playwright test -c e2e/playwright.config.ts",
    "test:e2e:admin": "pnpm db:reset && playwright test -c e2e/playwright.config.ts e2e/tests/admin*.spec.ts",
    "test:e2e:admin:seeded": "pnpm db:reset && playwright test -c e2e/playwright.config.ts e2e/tests/admin.smoke.spec.ts e2e/tests/admin.detection-seeded.spec.ts",
    "test:e2e:portal": "pnpm db:reset && playwright test -c e2e/playwright.config.ts e2e/tests/portal*.spec.ts",
    "test:e2e:portal:seeded": "pnpm db:reset && playwright test -c e2e/playwright.config.ts e2e/tests/portal.smoke.spec.ts e2e/tests/portal.tenant-switch.spec.ts",
    "test:e2e:cameras-isolation": "playwright test -c e2e/playwright.config.ts e2e/tests/portal.cameras-isolation.spec.ts",
    "test:stream": "pnpm --filter @app/stream-gateway test",
    "test:stream:load": "pnpm --filter @app/stream-gateway test:load",
    "test:stream:soak": "pnpm --filter @app/stream-gateway test:soak",
    "test:stream:soak:record": "pnpm --filter @app/stream-gateway test:soak:record"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.51.1",
    "@types/eslint__js": "^8.42.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.26.1"
  }
}
