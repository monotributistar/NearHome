{
  "name": "nearhome-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "setup": "bash scripts/setup.sh",
    "bootstrap": "bash scripts/setup.sh",
    "dev:api": "pnpm --filter @app/api dev",
    "dev:stream": "pnpm --filter @app/stream-gateway dev",
    "dev:event": "pnpm --filter @app/event-gateway dev",
    "dev:admin": "pnpm --filter @app/admin dev",
    "dev:portal": "pnpm --filter @app/portal dev",
    "dev:inference-bridge": "uvicorn apps/inference-bridge/app:app --host 0.0.0.0 --port 8090",
    "dev:stack:up": "docker compose -f infra/docker-compose.yml up -d",
    "dev:stack:down": "docker compose -f infra/docker-compose.yml down",
    "pilot:stack:up:local": "bash scripts/pilot/stack-up.sh local",
    "pilot:stack:down:local": "bash scripts/pilot/stack-down.sh local",
    "pilot:stack:up:onprem": "bash scripts/pilot/stack-up.sh onprem",
    "pilot:stack:up:onprem:tunnel": "bash scripts/pilot/stack-up.sh onprem tunnel",
    "pilot:stack:down:onprem": "bash scripts/pilot/stack-down.sh onprem",
    "pilot:smoke": "bash scripts/pilot/smoke-planes.sh",
    "pilot:harness:prepare": "bash scripts/pilot/virtual-harness.sh prepare",
    "pilot:harness:run": "bash scripts/pilot/virtual-harness.sh run",
    "pilot:harness:cleanup": "bash scripts/pilot/virtual-harness.sh cleanup",
    "pilot:harness": "bash scripts/pilot/virtual-harness.sh full",
    "db:reset": "pnpm --filter @app/api db:reset",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:admin": "playwright test -c e2e/playwright.config.ts e2e/tests/admin*.spec.ts",
    "test:e2e:portal": "playwright test -c e2e/playwright.config.ts e2e/tests/portal*.spec.ts",
    "test:stream": "pnpm --filter @app/stream-gateway test",
    "test:stream:load": "pnpm --filter @app/stream-gateway test:load",
    "test:stream:soak": "pnpm --filter @app/stream-gateway test:soak",
    "test:stream:soak:record": "pnpm --filter @app/stream-gateway test:soak:record"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.51.1",
    "@types/eslint__js": "^8.42.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.26.1"
  }
}
