PILOT_EMAIL=admin@nearhome.dev
PILOT_PASSWORD=demo1234

# Optional: set explicit tenant id, otherwise first tenant from /tenants is used.
# PILOT_TENANT_ID=

PILOT_CAM1_NAME=PILOT_LAN_CAM_1
PILOT_CAM2_NAME=PILOT_LAN_CAM_2

# Put full RTSP URLs with your user/password.
# If credentials contain special chars, URL-encode them.
PILOT_CAM1_RTSP=rtsp://user:password@192.168.1.101:554/stream1
PILOT_CAM2_RTSP=rtsp://user:password@192.168.1.102:554/stream1

# Bridge reachable from host.
BRIDGE_URL=http://localhost:8090

# Node endpoints as seen by inference-bridge container.
YOLO_URL=http://inference-node-yolo:8091
MEDIAPIPE_URL=http://inference-node-mediapipe:8092

PILOT_JOB_TIMEOUT_S=120
PILOT_JOB_POLL_S=3
