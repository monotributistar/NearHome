PILOT_EMAIL=admin@nearhome.dev
PILOT_PASSWORD=demo1234

# Optional: set explicit tenant id, otherwise first tenant from /tenants is used.
# PILOT_TENANT_ID=

PILOT_CAM1_NAME=PILOT_PUBLIC_FEED_1
PILOT_CAM2_NAME=PILOT_PUBLIC_FEED_2

# Public feeds for integration testing. The variable is named RTSP for historical reasons,
# but stream-gateway/ffmpeg can ingest HTTP HLS sources as well.
PILOT_CAM1_RTSP=https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8
PILOT_CAM2_RTSP=https://devstreaming-cdn.apple.com/videos/streaming/examples/img_bipbop_adv_example_ts/master.m3u8

# Bridge reachable from host.
BRIDGE_URL=http://localhost:8090
NODE_AUTH_ADMIN_SECRET=dev-node-auth-admin-secret

# Node endpoints as seen by inference-bridge container.
YOLO_URL=http://inference-node-yolo:8091
MEDIAPIPE_URL=http://inference-node-mediapipe:8092

PILOT_JOB_TIMEOUT_S=120
PILOT_JOB_POLL_S=3
