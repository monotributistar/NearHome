ONPREM_ADMIN_ORIGIN=http://localhost:5173
ONPREM_PORTAL_ORIGIN=http://localhost:5174
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# Host path where remote vault is mounted (NFS/CIFS/SSHFS over LAN/VPN)
ONPREM_VAULT_REMOTE_PATH=/tmp/nearhome-remote-vault

STREAM_MEDIA_ENGINE=process

NODE_AUTH_JWT_SECRET=dev-node-auth-secret
NODE_AUTH_ADMIN_SECRET=dev-node-auth-admin-secret
NODE_HEARTBEAT_TTL_MS=60000
STREAM_TRANSCODER_PRESET=ffmpeg-hls-retention
STREAM_TRANSCODER_DRY_RUN=1

STREAM_STORAGE_DEFAULT_VAULT_ID=vault-remote
STREAM_STORAGE_VAULTS_JSON=[{"id":"vault-remote","basePath":"/data/storage-remote","description":"remote mounted vault"}]
STREAM_STORAGE_PLAN_VAULT_MAP_JSON={}
STREAM_STORAGE_FAILOVER_ENABLED=1
STREAM_STORAGE_HEALTHCHECK_ENABLED=1
STREAM_STORAGE_HEALTHCHECK_MS=30000
STREAM_STORAGE_HEALTHCHECK_WRITE_PROBE=1
STREAM_STORAGE_TENANT_QUOTAS_JSON={}
STREAM_STORAGE_DEFAULT_TENANT_QUOTA_BYTES=0
STREAM_STORAGE_TENANT_QUOTA_TARGET_PCT=90
STREAM_EVENT_CLIP_STRATEGY=concat
STREAM_EVENT_CLIP_FFMPEG_BIN=ffmpeg
STREAM_OBSERVE_SCRATCH_DIR=./storage-observe

STREAM_DEFAULT_INGEST_TRANSPORT=tcp
STREAM_DEFAULT_INGEST_ENCRYPTION=required
STREAM_DEFAULT_INGEST_TUNNEL=https

STREAM_RETENTION_ENABLED=1
STREAM_RETENTION_DAYS=7
STREAM_RETENTION_SWEEP_MS=300000
STREAM_RETENTION_MIN_FILE_AGE_SECONDS=45
STREAM_RETENTION_MAX_DISK_USAGE_PCT=85
STREAM_RETENTION_TARGET_DISK_USAGE_PCT=75
STREAM_RETENTION_FILE_EXTENSIONS=.ts,.m4s,.mp4,.mkv,.fmp4

STREAM_RETENTION_SEGMENT_SECONDS=4
STREAM_RETENTION_LIVE_LIST_SIZE=15

STREAM_FFMPEG_VIDEO_MODE=copy
STREAM_FFMPEG_TARGET_BITRATE_KBPS=2500
STREAM_FFMPEG_MAXRATE_KBPS=3000
STREAM_FFMPEG_BUFSIZE_KBPS=5000

ALERTMANAGER_WEBHOOK_DEFAULT_URL=http://alert-webhook:80/default
ALERTMANAGER_WEBHOOK_CRITICAL_URL=http://alert-webhook:80/critical
ALERTMANAGER_WEBHOOK_WARNING_URL=http://alert-webhook:80/warning
ALERTMANAGER_WEBHOOK_INFO_URL=http://alert-webhook:80/info
